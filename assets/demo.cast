[24.92, "o", "\u001b[2m## project-frontend-context-protocol\u001b[0m\r\n"]
[25.17, "o", "\u001b[2mFrontend analog of a Brand Context Protocol: design tokens +\u001b[0m\r\n"]
[25.42, "o", "\u001b[2mcomponent API conventions + a11y/code-style rules + ADRs as\u001b[0m\r\n"]
[25.67, "o", "\u001b[2mmachine-readable files, with conformance gates that refine it.\u001b[0m\r\n"]
